# Supabase Postgres (direct connection string for SQLAlchemy/Alembic)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Redis (Railway plugin or local)
REDIS_URL=redis://localhost:6379/0

# Supabase Auth
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_ANON_KEY=your-anon-key

# Admin users (comma-separated emails)
ADMIN_EMAILS=admin@example.com

# Google Places API key (server-side, for location autocomplete)
# Enable "Places API (New)" + billing in Google Cloud, then paste the API key.
GOOGLE_MAPS_API_KEY=

# API
API_CORS_ORIGINS=http://localhost:5173,https://your-web.railway.app
RATE_LIMIT_ANONYMOUS=60/minute
RATE_LIMIT_AUTHENTICATED=300/minute

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
